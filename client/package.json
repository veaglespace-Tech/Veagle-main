{
  "name": "veagle-space-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:next": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true, maxRetries: 10, retryDelay: 250 })\"",
    "dev": "set \"NODE_OPTIONS=--max-old-space-size=6144 --max-semi-space-size=256\" && next dev --turbopack",
    "dev:fresh": "npm run clean:next && npm run dev",
    "dev:webpack": "set \"NODE_OPTIONS=--max-old-space-size=6144 --max-semi-space-size=256\" && next dev --webpack",
    "build": "set \"NODE_OPTIONS=--max-old-space-size=8192 --max-semi-space-size=256\" && next build --turbopack",
    "build:webpack": "set \"NODE_OPTIONS=--max-old-space-size=8192 --max-semi-space-size=256\" && next build --webpack",
    "start": "set \"NODE_OPTIONS=--max-old-space-size=4096 --max-semi-space-size=128\" && next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "daisyui": "^5.5.19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4"
  }
}
